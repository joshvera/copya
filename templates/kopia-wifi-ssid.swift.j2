import AppKit
import CoreLocation
import CoreWLAN
import Foundation

final class LocationAuthorizationApp: NSObject, NSApplicationDelegate, CLLocationManagerDelegate {
    private let manager = CLLocationManager()
    private let interfaceName: String?
    private let printStatus: Bool
    private let visiblePermissionWindow: Bool
    private let requestPermission: Bool
    private let printSSIDAfterAuthorization: Bool
    private var window: NSWindow?
    private var statusLabel: NSTextField?
    private var finished = false

    init(
        interfaceName: String?,
        printStatus: Bool,
        visiblePermissionWindow: Bool,
        requestPermission: Bool,
        printSSIDAfterAuthorization: Bool
    ) {
        self.interfaceName = interfaceName
        self.printStatus = printStatus
        self.visiblePermissionWindow = visiblePermissionWindow
        self.requestPermission = requestPermission
        self.printSSIDAfterAuthorization = printSSIDAfterAuthorization
        super.init()
        manager.delegate = self
        manager.desiredAccuracy = kCLLocationAccuracyThreeKilometers
    }

    func applicationDidFinishLaunching(_ notification: Notification) {
        NSApp.setActivationPolicy(.regular)
        showWindow(visible: visiblePermissionWindow)
        NSApp.activate(ignoringOtherApps: true)

        DispatchQueue.main.async {
            self.requestAuthorizationIfNeeded()
        }

        DispatchQueue.main.asyncAfter(deadline: .now() + 60) {
            self.finish(self.manager.authorizationStatus)
        }
    }

    func locationManagerDidChangeAuthorization(_ manager: CLLocationManager) {
        let status = manager.authorizationStatus
        updateStatusLabel(status)

        if isAuthorized(status) || status == .denied || status == .restricted {
            finish(status)
        }
    }

    func locationManager(_ manager: CLLocationManager, didUpdateLocations locations: [CLLocation]) {
        finish(manager.authorizationStatus)
    }

    func locationManager(_ manager: CLLocationManager, didFailWithError error: Error) {
        let status = manager.authorizationStatus
        if status != .notDetermined {
            finish(status)
        }
    }

    private func showWindow(visible: Bool) {
        let contentRect = visible
            ? NSRect(x: 0, y: 0, width: 460, height: 130)
            : NSRect(x: 0, y: 0, width: 1, height: 1)
        let window = NSWindow(
            contentRect: contentRect,
            styleMask: [.titled, .closable],
            backing: .buffered,
            defer: false
        )
        window.title = "Kopia WiFi SSID Helper"
        window.center()
        window.alphaValue = visible ? 1.0 : 0.01

        if visible {
            let label = NSTextField(labelWithString: "Allow Location access so Kopia can read the current Wi-Fi network name and skip metered backups.")
            label.frame = NSRect(x: 24, y: 56, width: 412, height: 48)
            label.lineBreakMode = .byWordWrapping
            label.maximumNumberOfLines = 2
            label.alignment = .center
            window.contentView?.addSubview(label)

            let statusLabel = NSTextField(labelWithString: "Permission status: \(statusName(manager.authorizationStatus))")
            statusLabel.frame = NSRect(x: 24, y: 24, width: 412, height: 20)
            statusLabel.alignment = .center
            window.contentView?.addSubview(statusLabel)
            self.statusLabel = statusLabel
        }

        window.makeKeyAndOrderFront(nil)
        self.window = window
    }

    private func requestAuthorizationIfNeeded() {
        updateStatusLabel(manager.authorizationStatus)

        if !requestPermission {
            finish(manager.authorizationStatus)
            return
        }

        switch manager.authorizationStatus {
        case .authorizedAlways, .denied, .restricted:
            finish(manager.authorizationStatus)
            return
        case .notDetermined:
            break
        @unknown default:
            finish(manager.authorizationStatus)
            return
        }

        manager.requestAlwaysAuthorization()
        manager.startUpdatingLocation()
    }

    private func updateStatusLabel(_ status: CLAuthorizationStatus) {
        statusLabel?.stringValue = "Permission status: \(statusName(status))"
    }

    private func finish(_ status: CLAuthorizationStatus) {
        guard !finished else {
            return
        }
        finished = true
        manager.stopUpdatingLocation()

        if printStatus {
            print(statusName(status))
            fflush(stdout)
        }

        if isAuthorized(status), printSSIDAfterAuthorization {
            exit(printSSID(interfaceName: interfaceName))
        }

        exit(isAuthorized(status) ? 0 : 3)
    }
}

func runApp(
    interfaceName: String?,
    printStatus: Bool,
    visiblePermissionWindow: Bool,
    requestPermission: Bool,
    printSSIDAfterAuthorization: Bool
) -> Never {
    let app = NSApplication.shared
    let delegate = LocationAuthorizationApp(
        interfaceName: interfaceName,
        printStatus: printStatus,
        visiblePermissionWindow: visiblePermissionWindow,
        requestPermission: requestPermission,
        printSSIDAfterAuthorization: printSSIDAfterAuthorization
    )
    app.delegate = delegate
    app.run()
    exit(3)
}

func authorizationStatus() -> CLAuthorizationStatus {
    CLLocationManager().authorizationStatus
}

func statusName(_ status: CLAuthorizationStatus) -> String {
    switch status {
    case .notDetermined:
        return "notDetermined"
    case .restricted:
        return "restricted"
    case .denied:
        return "denied"
    case .authorizedAlways:
        return "authorizedAlways"
    @unknown default:
        return "unknown"
    }
}

func isAuthorized(_ status: CLAuthorizationStatus) -> Bool {
    status == .authorizedAlways
}

func printSSID(interfaceName: String?) -> Int32 {
    let client = CWWiFiClient.shared()
    let wifiInterface: CWInterface?

    if let interfaceName, !interfaceName.isEmpty {
        wifiInterface = client.interface(withName: interfaceName)
    } else {
        wifiInterface = client.interface()
    }

    guard let wifiInterface else {
        fputs("kopia-wifi-ssid: no Wi-Fi interface found\n", stderr)
        return 4
    }

    if let ssid = wifiInterface.ssid(), !ssid.isEmpty {
        print(ssid)
        return 0
    }

    if let ssidData = wifiInterface.ssidData(),
       let ssid = String(data: ssidData, encoding: .utf8),
       !ssid.isEmpty {
        print(ssid)
        return 0
    }

    let status = authorizationStatus()
    if !isAuthorized(status) {
        fputs("kopia-wifi-ssid: location authorization is \(statusName(status)); run --request-location\n", stderr)
        return 3
    }

    fputs("kopia-wifi-ssid: SSID unavailable\n", stderr)
    return 2
}

func usage() -> Never {
    let message = """
    usage: kopia-wifi-ssid [--ssid [interface]] [--ssid-request [interface]] [--status] [--request-location]
    """
    fputs(message + "\n", stderr)
    exit(64)
}

let arguments = CommandLine.arguments.dropFirst().filter { !$0.hasPrefix("-psn_") }

if arguments.isEmpty || arguments[0] == "--ssid" {
    let interfaceName = arguments.count > 1 ? arguments[1] : nil
    runApp(
        interfaceName: interfaceName,
        printStatus: false,
        visiblePermissionWindow: false,
        requestPermission: false,
        printSSIDAfterAuthorization: true
    )
}

switch arguments[0] {
case "--status":
    runApp(
        interfaceName: nil,
        printStatus: true,
        visiblePermissionWindow: false,
        requestPermission: false,
        printSSIDAfterAuthorization: false
    )
case "--request-location":
    guard CLLocationManager.locationServicesEnabled() else {
        fputs("kopia-wifi-ssid: Location Services are disabled\n", stderr)
        exit(3)
    }

    runApp(
        interfaceName: arguments.count > 1 ? arguments[1] : nil,
        printStatus: true,
        visiblePermissionWindow: true,
        requestPermission: true,
        printSSIDAfterAuthorization: true
    )
case "--ssid-request":
    guard CLLocationManager.locationServicesEnabled() else {
        fputs("kopia-wifi-ssid: Location Services are disabled\n", stderr)
        exit(3)
    }

    runApp(
        interfaceName: arguments.count > 1 ? arguments[1] : nil,
        printStatus: false,
        visiblePermissionWindow: false,
        requestPermission: false,
        printSSIDAfterAuthorization: true
    )
default:
    usage()
}
